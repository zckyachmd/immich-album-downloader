{
  "name": "immich-album-downloader",
  "version": "1.0.6",
  "packageManager": "bun@1.2.21",
  "type": "module",
  "bin": {
    "immich-album-downloader": "./src/main.ts"
  },
  "scripts": {
    "download": "bun run src/main.ts",
    "download:all": "bun run src/main.ts --all",
    "download:resume": "bun run src/main.ts --resume-failed",
    "download:dry": "bun run src/main.ts --dry-run",
    "download:verbose": "bun run src/main.ts --verbose",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml,yaml}\"",
    "test": "IMMICH_API_KEY=test-api-key-1234567890 IMMICH_BASE_URL=https://example.com bun test --isolate",
    "test:watch": "IMMICH_API_KEY=test-api-key-1234567890 IMMICH_BASE_URL=https://example.com bun test --watch --isolate"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "inquirer": "^9.3.8",
    "p-limit": "^4.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.33",
    "prettier": "^3.7.4",
    "typescript": "^5.9.2"
  }
}
