{
  "name": "immich-album-downloader",
  "version": "1.0.8",
  "description": "CLI tool for downloading and backing up Immich albums with resume support, filtering, and Docker support.",
  "packageManager": "bun@1.2.21",
  "type": "module",
  "bin": {
    "immich-album-downloader": "./src/main.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "USAGE.md"
  ],
  "scripts": {
    "download": "bun run src/main.ts",
    "download:all": "bun run src/main.ts --all",
    "download:resume": "bun run src/main.ts --resume-failed",
    "download:dry": "bun run src/main.ts --dry-run",
    "download:verbose": "bun run src/main.ts --verbose",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun test && bun run typecheck",
    "test": "IMMICH_API_KEY=fake-api-key-for-tests IMMICH_BASE_URL=https://example.com bun test --isolate",
    "test:watch": "IMMICH_API_KEY=fake-api-key-for-tests IMMICH_BASE_URL=https://example.com bun test --watch --isolate"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "inquirer": "^9.3.8",
    "p-limit": "^4.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.9.2"
  }
}
